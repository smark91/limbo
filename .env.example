# ============================================
# Limbo — Environment Configuration
# ============================================

# --- Database ---
DB_DRIVER=postgres # or sqlite
POSTGRES_URL=postgresql://user:password@postgres:5432/limbo?sslmode=disable
SQLITE_PATH=/data/limbo.db

# --- Seerr ---
SEERR_URL=http://seerr:5055
SEERR_PUBLIC_URL=https://seerr.example.com
SEERR_API_KEY=your-seerr-api-key

# --- Discord (optional — omit to disable notifications) ---
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook

# --- App Settings ---
RELEASE_COUNTRY=US
SCAN_INTERVAL_MINUTES=10
ALERT_DELAY_MINUTES=10 # Minimum request age in minutes before notifying (gives automation time to download first)
ALERT_MAX_AGE_MINUTES=1440 # Maximum request age in minutes to notify (prevents spamming old/stale requests)
LIMBO_PORT=3000

# --- Logging ---
LOG_LEVEL=info # debug, info, warn, error
LOG_FORMAT=text # text, json

# --- Web Push Notifications / PWA (optional — auto-generated if empty) ---
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@limbo.local
