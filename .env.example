# ============================================
# Limbo — Environment Configuration
# ============================================

# --- Database ---
DB_DRIVER=postgres # or sqlite
DB_DSN=postgresql://user:password@postgres:5432/limbo?sslmode=disable # or /data/limbo.db

# --- Seerr ---
SEERR_URL=http://seerr:5055
SEERR_PUBLIC_URL=https://seerr.example.com
SEERR_API_KEY=your-seerr-api-key

# --- Discord (optional — omit to disable notifications) ---
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook

# --- App Settings ---
RELEASE_COUNTRY=US
SCAN_INTERVAL_MINUTES=10

# Minimum request age (in minutes) before Discord notification (gives automation time to download first)
ALERT_THRESHOLD_MINUTES=10
# Age window (in minutes) after threshold qualifying for notifications (prevents spamming old/stale requests)
ALERT_WINDOW_MINUTES=1440

LIMBO_PORT=3000
